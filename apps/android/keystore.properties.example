# Copy this file to keystore.properties or run:
# apps/android/scripts/generate-android-release-keystore.sh
#
# keystore.properties is intentionally ignored by git because it contains
# release signing secrets.
storeFile=release/SmsPusher-release.jks
storePassword=replace-with-keystore-password
keyAlias=smspusher-release
keyPassword=replace-with-key-password
